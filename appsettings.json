{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=jaezoo.db"
  },
  "Jwt": {
    "Key": "SET_A_STRONG_SECRET_KEY_FOR_LOCAL_DEV_ChangeMe",
    "Issuer": "JaeZoo",
    "Audience": "JaeZooClient",
    "ExpiresMinutes": 60
  },
  "Swagger": true,
  "AllowedHosts": "*",
  "Files": {
    "StoragePath": "/tmp/jaezoo/uploads",
    "MaxUploadBytes": 2147483648,
    "AllowedContentTypes": [
      "image/jpeg",
      "image/png",
      "image/webp",
      "image/gif",
      "video/mp4",
      "audio/mpeg",
      "audio/ogg",
      "application/pdf",
      "text/plain",
      "application/zip",
      "application/x-zip-compressed"
    ],
    "Antivirus": {
      "Enabled": true,
      "Mode": "Basic",
      "PollSeconds": 3,
      "BatchSize": 4,
      "ScanTimeoutSeconds": 45,
      "ClamAvHost": "127.0.0.1",
      "ClamAvPort": 3310,
      "MaxBytesToScanInBasicMode": 1048576
    }
  },
  "ObjectStorage": {
    "Provider": "Yandex",
    "Bucket": "jaezoo-files",
    "Endpoint": "https://s3.yandexcloud.net",
    "AccessKey": "YOUR_ACCESS_KEY",
    "SecretKey": "YOUR_SECRET_KEY",
    "PublicBaseUrl": "https://storage.yandexcloud.net",
    "Buckets": {
      "Avatars": "jaezoo-avatars",
      "Files": "jaezoo-files",
      "Music": "jaezoo-music",
      "Photos": "jaezoo-photos",
      "Videos": "jaezoo-videos"
    }
  },
  "Turn": {
    "Secret": "SET_TURN_SHARED_SECRET",
    "TtlSeconds": 3600,
    "Realm": "turn.jaezoo.ru",
    "Urls": [
      "stun:turn.jaezoo.ru:3478",
      "turn:turn.jaezoo.ru:3478?transport=udp",
      "turn:turn.jaezoo.ru:3478?transport=tcp",
      "turns:turn.jaezoo.ru:5349?transport=tcp"
    ]
  },
  "LiveKit": {
    "Url": "wss://sfu.jaezoo.ru",
    "ApiKey": "jaezoo_sfu_prod",
    "ApiSecret": "",
    "TokenTtlMinutes": 120,
    "ParticipantStaleSeconds": 90
  },
  "Ads": {
    "Prefix": "ads",
    "SignedUrlTtlMinutes": 60,
    "MaxImageBytes": 8388608,
    "Bucket": "jaezoo-updates-prod",
    "Endpoint": "",
    "Region": "",
    "AccessKey": "",
    "SecretKey": ""
  },
  "Postbox": {
    "Enabled": false,
    "Host": "postbox.cloud.yandex.net",
    "Port": 587,
    "EnableSsl": true,
    "UserName": "",
    "Password": "",
    "FromEmail": "noreply@jaezoo.ru",
    "FromName": "JaeZoo",
    "CodeLifetimeMinutes": 15,
    "ResendCooldownSeconds": 60,
    "MaxAttempts": 5
  },
  "Messages": {
    "Encryption": {
      "Enabled": false,
      "KeyBase64": "",
      "MigrateExistingOnStartup": false
    }
  }
